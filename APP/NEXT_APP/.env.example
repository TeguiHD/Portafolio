# Environment variables for Portfolio

# Database - PostgreSQL connection
DATABASE_URL="postgresql://postgres:password@localhost:5432/portfolio_db?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
# Set to "true" when the app runs behind Docker/reverse proxy in production
AUTH_TRUST_HOST="false"

# Security: CORS + Redirect allowlist
# Production example: "https://floresdyd.cl,https://www.floresdyd.cl"
CORS_ALLOWED_ORIGINS="http://localhost:3000"
# Internal redirect prefixes (comma-separated)
REDIRECT_ALLOWLIST="/,/admin,/acceso,/cotizacion,/herramientas"

# Security (required)
# Used to hash + encrypt sensitive identifiers (emails, etc). Min 32 chars.
# Generate with: openssl rand -base64 48 | tr -d '\n'
ENCRYPTION_KEY="change-me-32-chars-minimum-change-me!!!"

# Password Pepper - adds a server-side secret to all password hashes.
# If compromised DB is leaked, hashes are useless without this pepper.
# Generate with: openssl rand -base64 32
PASSWORD_PEPPER="change-me-generate-with-openssl"

# Internal API Secret - used only for internal service-to-service calls.
# NEVER reuse ENCRYPTION_KEY here (NIST SP 800-57: one key = one purpose).
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET="change-me-generate-with-openssl"

# Seed admin (required when running prisma/seed.ts)
ADMIN_EMAIL="admin@example.com"
# Generate strong password with: openssl rand -base64 24
ADMIN_PASSWORD="change-me"

# Contact Links (public - exposed to client)
NEXT_PUBLIC_CALENDLY_URL="https://calendly.com/tu-usuario"
NEXT_PUBLIC_WHATSAPP_NUMBER="56912345678"
NEXT_PUBLIC_CONTACT_EMAIL="contacto@nicoholas.dev"

# Optional: OAuth providers (uncomment to enable)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_ID=""
# GITHUB_SECRET=""

# OpenRouter API - DeepSeek R1T2 Chimera (Free tier)
DEEPSEEK_OPENROUTER_API_KEY="your-openrouter-api-key"
# Optional alias used by jobs CV adaptation service
OPENROUTER_API_KEY=""

# Groq API key (used by jobs CV adaptation + CV chat)
GROQ_API_KEY=""

# Jobs CV AI adaptation defaults (optional)
JOBS_AI_PROVIDER_DEFAULT="AUTO"
JOBS_AI_GROQ_MODEL="qwen/qwen3-32b"
JOBS_AI_OPENROUTER_MODEL="google/gemma-3-27b-it:free"

# Redis (optional - app has memory fallback)
# Local example:
# REDIS_URL="redis://:password@localhost:6379"
# Docker example:
# REDIS_URL="redis://:password@redis:6379"

# Digital Pulse - Web Push Notifications (optional)
# Generate with: npx web-push generate-vapid-keys
PULSE_PUSH_BOOT="false"
PULSE_PUSH_POLL_MS="900000"
WEB_PUSH_CONTACT_EMAIL="contacto@nicoholas.dev"
WEB_PUSH_VAPID_PUBLIC_KEY=""
WEB_PUSH_VAPID_PRIVATE_KEY=""

# SuperAdmin VPS Control (optional)
# VPS_HOST="your-server-ip-or-hostname"
# VPS_SSH_PORT="22"
# VPS_USER="your-ssh-user"
# Set either VPS_SSH_PASS or VPS_SSH_KEY
# VPS_SSH_PASS="change-me"
# VPS_SSH_KEY="-----BEGIN OPENSSH PRIVATE KEY-----..."
